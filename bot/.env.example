# -------------------------------------------------------
# Dev Codes Discord Bot — Environment Variables
# Copy this file to .env and fill in the values
# -------------------------------------------------------

# Your bot token from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# The ID of your Dev Codes Discord server (right-click server → Copy Server ID)
GUILD_ID=your_guild_id_here

# Port the API server listens on (default 3001)
PORT=3001

# How long (ms) to keep the guild data cache before re-fetching (default 60 seconds)
CACHE_TTL_MS=60000
